pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'studydocs/devops-python-app-2'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/DixitMehta/Devops-python-app-2.git'   
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t %DOCKER_IMAGE%:%IMAGE_TAG% devops-python-app/"
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat '''
                    echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin
                    docker push %DOCKER_IMAGE%:%IMAGE_TAG%
                    '''
                }
            }
        }

        stage('Update Manifest & Push') {
            steps {
                withCredentials([usernamePassword(
                credentialsId: 'Github',
                usernameVariable: 'GIT_USER',
                passwordVariable: 'GIT_PASS'
            )]) 
            {
                powershell '''

                $file = "devops-python-infra/App Deployment.yaml"
                $imageName = "studydocs/devops-python-app-2"
                $tag = $env:IMAGE_TAG

                Write-Host "Updating image to ${imageName}:$tag"

                # Read file
                $content = Get-Content "$file"

                # Replace ONLY your app image
                $updated = $content -replace "studydocs/devops-python-app-2:.*", "$imageName`:$tag"

                # Save file
                $updated | Set-Content "$file"

                # Git config
                git config user.name "Jenkins CI"
                git config user.email "jenkins@yourcompany.com"

                # Commit changes
                git add "$file"
                git commit -m "Updated image to $tag"

                # Push using credentials
                git push https://$env:GIT_USER:$env:GIT_PASS@github.com/DixitMehta/Devops-python-app-2.git HEAD:main

                Write-Host "Manifest updated and pushed successfully"

                '''
    }
}
}

        }
}
