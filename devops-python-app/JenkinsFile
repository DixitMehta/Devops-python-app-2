pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'studydocs/devops-python-app-2'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/DixitMehta/Devops-python-app-2.git',
                    # credentialsId: 'Github'    #use when repo is private
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t %DOCKER_IMAGE%:%IMAGE_TAG% devops-python-app/"
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat '''
                    echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin
                    docker push %DOCKER_IMAGE%:%IMAGE_TAG%
                    '''
                }
            }
        }

        stage('Update Manifest & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'Github',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {

                    powershell '''
                    
                    git config user.name "Jenkins CI"
                    git config user.email "jenkins@yourcompany.com"

                    # Update image tag inside SAME repo
                    (Get-Content devops-python-infra/"App Deployment.yaml") -replace 'myapp:.*',"myapp:$env:IMAGE_TAG" | Set-Content devops-python-infra/"App Deployment.yaml"

                    git add "devops-python-infra/App Deployment.yaml"
                    git commit -m "Update image to $env:IMAGE_TAG"

                    # Push using credentials
                    git push https://$env:GIT_USER:$env:GIT_PASS@github.com/DixitMehta/Devops-python-app-2.git HEAD:main
                    
                    '''
                }
            }
        }
    }
}
