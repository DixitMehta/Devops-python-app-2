pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'studydocs/devops-python-app-2'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout App Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/DixitMehta/Devops-python-app-2.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t %DOCKER_IMAGE%:%IMAGE_TAG% devops-python-app/"
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat '''
                    echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin
                    docker push %DOCKER_IMAGE%:%IMAGE_TAG%
                    '''
                }
            }
        }

        stage('Clone Manifest Repo') {
            steps {
                dir('infra-repo') {
                    git branch: 'main',
                        url: 'https://github.com/DixitMehta/devops-python-infra.git'
                }
            }
        }

        stage('Update Manifest & Push') {
            steps {
                dir('infra-repo') {
                    withCredentials([usernamePassword(
                        credentialsId: 'git-creds',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )]) {

                        powershell '''
                        
                        git config user.name "Jenkins CI"
                        git config user.email "jenkins@yourcompany.com"

                        # Replace image tag dynamically
                        (Get-Content Deployment.yaml) -replace 'myapp:.*',"myapp:$env:IMAGE_TAG" | Set-Content Deployment.yaml

                        git add Deployment.yaml
                        git commit -m "Update image to $env:IMAGE_TAG"

                        git remote set-url origin https://$env:GIT_USER:$env:GIT_PASS@github.com/DixitMehta/devops-python-infra.git

                        git push origin HEAD:main
                        
                        '''
                    }
                }
            }
        }
    }
}
