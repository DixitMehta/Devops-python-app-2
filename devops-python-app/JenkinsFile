pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'studydocs/devops-python-app-2'
    }

	stages {
        stage('Configure Git') {
            steps {
                bat '''
                    git config user.name "Jenkins CI"
                    git config user.email "jenkins@yourcompany.com"
                '''
            }
        }

		stage('Checkout') {
        	    steps {
            	    git branch: 'main',
                	    url: 'https://github.com/DixitMehta/Devops-python-app-2.git'
            }
        }

        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/DixitMehta/Devops-python-app-2.git'
            }
        }

        stage('Build') {
            steps {
                bat 'docker build -t %DOCKER_IMAGE% devops-python-app/'
            }
        }

        stage('Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat 'echo %PASS% | docker login -u %USER% --password-stdin'
                    bat 'docker push %DOCKER_IMAGE%'
                }
            }
        }
        

	stage('Update Manifest Repo') {
    steps {
        powershell '''
        (Get-Content devops-python-infra/deployment.yaml) -replace 'myapp:v1','myapp:v2' | Set-Content devops-python-infra/deployment.yaml
        git add devops-python-infra/Deployment.yaml
		git commit -m "Update Deployment.yaml to latest version"
        git push origin main --verbose
        '''
    }
}
}
}
